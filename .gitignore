# Rust build output
/target/
**/target/

# Cargo lock — keep for binaries, omit for libraries.
# KOVA services are binaries; keeping Cargo.lock ensures reproducible CI builds.
# Do NOT add Cargo.lock here.

# sqlx offline query cache — commit only the checked-in .sqlx/ directories
# generated by `cargo sqlx prepare`. Intermediate artefacts go here:
**/.sqlx/

# Environment files — never commit secrets
.env
.env.*
!.env.example
*.env

# IDE / editor
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.DS_Store

# OS noise
Thumbs.db

# Compiled protobuf descriptors (generated, not source)
*.pb.go
*.pb.rs
proto/gen/

# Test coverage artefacts
lcov.info
tarpaulin-report.html
coverage/

# Docker build context overrides
.dockerignore.local

# Secrets accidentally dropped in repo root
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
